{
  "name": "zcvios-core-alpha",
  "version": "1.1.0-alpha",
  "private": true,
  "engines": {
    "node": ">=22.18.0 <23",
    "npm": ">=10 <11"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init_alpha",
    "prisma:push": "prisma db push",
    "preseed": "npm run prisma:generate",
    "seed": "node scripts/run-seed.mjs",
    "verify:repository-hygiene": "node scripts/verify-repository-hygiene.mjs",
    "verify:ci-policy": "node scripts/verify-ci-policy.mjs",
    "verify:toolchain-policy": "node scripts/verify-toolchain-policy.mjs",
    "verify:offline-fonts": "node scripts/verify-offline-fonts.mjs",
    "verify:desktop-shell": "node scripts/verify-desktop-shell.mjs",
    "verify:desktop-persistence": "node scripts/verify-desktop-persistence.mjs",
    "verify:linux-package-metadata": "node scripts/verify-linux-package-metadata.mjs",
    "test:core": "npm run verify:repository-hygiene && npm run verify:ci-policy && npm run verify:toolchain-policy && npm run verify:offline-fonts && tsx scripts/verify-core-engine.ts && tsx scripts/verify-application-services.mjs && tsx scripts/verify-identity-boundary.mjs && npm run verify:desktop-shell && npm run verify:desktop-persistence && npm run verify:linux-package-metadata",
    "test": "node scripts/run-pytest.mjs -q tests",
    "test:privacy": "node scripts/run-pytest.mjs -q tests/test_rpc_authenticated_flows.py -k export"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@libsql/client": "^0.17.0",
    "@prisma/adapter-libsql": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.576.0",
    "next": "16.2.6",
    "next-auth": "^4.24.14",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-is": "^19.2.4",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": ">=8.5.10",
    "@hono/node-server": ">=1.19.13",
    "hono": ">=4.12.25",
    "uuid": ">=14.0.0",
    "ws": ">=8.21.0",
    "dompurify": ">=3.4.11",
    "esbuild": ">=0.28.1",
    "js-yaml": ">=4.2.0",
    "@babel/core": ">=7.29.6"
  }
}
